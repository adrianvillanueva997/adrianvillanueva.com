---
import { Icon } from "astro-icon/components";
import { readFileSync } from "fs";
import { join } from "path";
import avatar from "@/assets/resume/avatar.png";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE_TITLE } from "@/consts";

const resumePath = join(process.cwd(), "src/data/resume.yaml");
const resumeContent = readFileSync(resumePath, "utf8");
const { load } = await import("js-yaml");
const {
	personal,
	experience,
	education,
	skills,
	languages: langList,
} = load(resumeContent) as any;

function formatDate(dateStr: string): string {
	if (dateStr === "Present") return "Present";
	const [y, m] = dateStr.split("-");
	const months = [
		"Jan",
		"Feb",
		"Mar",
		"Apr",
		"May",
		"Jun",
		"Jul",
		"Aug",
		"Sep",
		"Oct",
		"Nov",
		"Dec",
	];
	return m ? `${months[parseInt(m) - 1]} ${y}` : y;
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Resume - ${SITE_TITLE}`}
			description="Download my CV or view my professional experience, skills, and education."
		/>
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to content</a>
		<Header />
		<main id="main-content" class="resume-page" transition:name="page">
			<aside class="resume-sidebar">
				<div class="resume-headshot">
					<img src={avatar.src} alt={personal.name} class="headshot" width={96} height={96} />
				</div>
				<div class="sidebar-section">
					<h3 class="sidebar-heading">Contact</h3>
					<div class="sidebar-line">
						<Icon name="mdi:map-marker" size={14} />
						{personal.location}
					</div>
					<div class="sidebar-line">
						<Icon name="mdi:email" size={14} />
						{personal.email}
					</div>
				</div>
				<div class="sidebar-section">
					<h3 class="sidebar-heading">Languages</h3>
					{langList.map((lang) => (
						<div class="sidebar-line sidebar-lang">
							<span>{lang.name}</span>
							<span class="lang-level">{lang.level}</span>
						</div>
					))}
				</div>
				<a href="/resume.pdf" class="resume-dl" download>
					<Icon name="mdi:download" size={16} />
					DOWNLOAD CV
				</a>
			</aside>

			<div class="resume-main">
				<header class="resume-hero">
					<h1 class="resume-name">{personal.name}</h1>
					<p class="resume-title">{personal.title}</p>
					<p class="resume-summary">{personal.summary}</p>
				</header>

				<section class="resume-section">
					<h2 class="section-heading">Experience</h2>
					<div class="experience-list">
						{experience.map((job, i) => (
							<div class="exp-entry">
								<div class="exp-marker">
									<div class="exp-dot"></div>
									{i < experience.length - 1 && <div class="exp-line"></div>}
								</div>
								<div class="exp-body">
									<div class="exp-header">
										<div>
											<h3 class="exp-role">{job.position}</h3>
											<p class="exp-company">{job.company}</p>
										</div>
										<div class="exp-meta">
											<span class="exp-date">{formatDate(job.startDate)} — {formatDate(job.endDate)}</span>
											<span class="exp-loc">
												<Icon name="mdi:map-marker" size={12} />
												{job.location}
											</span>
										</div>
									</div>
									<ul class="exp-highlights">
										{job.highlights.map((h) => (
											<li>{h}</li>
										))}
									</ul>
								</div>
							</div>
						))}
					</div>
				</section>

				<section class="resume-section">
					<h2 class="section-heading">Skills</h2>
					<div class="skills-clusters">
						{Object.entries(skills).map(([group, items]) => (
							<div class="skill-cluster">
								<h4 class="cluster-label">{group}</h4>
								<div class="cluster-tags">
									{items.map((skill) => (
										<span class="tag">{skill}</span>
									))}
								</div>
							</div>
						))}
					</div>
				</section>

				<section class="resume-section">
					<h2 class="section-heading">Education</h2>
					{education.map((edu) => (
						<div class="edu-entry">
							<h3 class="edu-degree">{edu.degree}</h3>
							<p class="edu-institution">{edu.institution}</p>
							<div class="edu-meta">
								<span>{edu.location}</span>
								<span>{edu.startDate} — {edu.endDate}</span>
							</div>
						</div>
					))}
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.resume-page {
		max-width: 960px;
		margin: 0 auto;
		padding: 3rem 2rem;
		display: grid;
		grid-template-columns: 220px 1fr;
		gap: 2.5rem;
		animation: fadeInUp 0.6s ease-out;
	}

	.resume-sidebar {
		position: sticky;
		top: 6rem;
		align-self: start;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.resume-headshot {
		text-align: center;
	}

	.headshot {
		border-radius: 50%;
		border: 2px solid var(--accent-primary);
		box-shadow: 0 0 16px var(--accent-primary-glow);
	}

	.sidebar-section {
		padding-top: 1rem;
		border-top: 1px solid var(--border-color);
	}

	.sidebar-heading {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.6rem;
		color: var(--accent-primary);
		letter-spacing: 0.15em;
		margin: 0 0 0.75rem 0;
		text-transform: uppercase;
	}

	.sidebar-line {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.75rem;
		color: var(--text-muted);
		font-family: 'JetBrains Mono', monospace;
		margin-bottom: 0.4rem;
		word-break: break-all;
	}

	.sidebar-line :global(svg) {
		color: var(--accent-primary);
		flex-shrink: 0;
	}

	.sidebar-lang {
		justify-content: space-between;
	}

	.lang-level {
		color: var(--accent-primary);
		font-size: 0.65rem;
		padding: 0.1rem 0.35rem;
		border: 1px solid rgba(0, 230, 138, 0.25);
		border-radius: var(--radius-sm);
		background: var(--accent-primary-subtle);
		flex-shrink: 0;
	}

	.resume-dl {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		padding: 0.6rem 1rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		color: var(--text-secondary);
		text-decoration: none;
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
		transition: all var(--transition-base);
	}

	.resume-dl:hover {
		color: var(--accent-primary);
		border-color: rgba(0, 230, 138, 0.25);
	}

	.resume-main {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.resume-hero {
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border-color);
	}

	.resume-name {
		font-size: clamp(1.5rem, 4vw, 2rem);
		margin: 0 0 0.25rem 0;
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.resume-title {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.9rem;
		color: var(--accent-primary);
		margin: 0 0 0.75rem 0;
	}

	.resume-summary {
		font-size: 0.9rem;
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.6;
	}

	.section-heading {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.65rem;
		color: var(--accent-primary);
		letter-spacing: 0.15em;
		margin: 0 0 1.25rem 0;
		padding: 0 0 0.5rem 0;
		border-bottom: 1px solid var(--border-color);
		text-transform: uppercase;
	}

	.section-heading::after {
		display: none;
	}

	.experience-list {
		display: flex;
		flex-direction: column;
	}

	.exp-entry {
		display: flex;
		gap: 1.25rem;
	}

	.exp-marker {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding-top: 0.35rem;
	}

	.exp-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		border: 2px solid var(--accent-primary);
		background: var(--bg-primary);
		flex-shrink: 0;
		box-shadow: 0 0 8px var(--accent-primary-glow);
	}

	.exp-line {
		width: 2px;
		flex: 1;
		background: linear-gradient(180deg, var(--accent-primary), transparent);
		margin-top: 0.4rem;
		opacity: 0.3;
	}

	.exp-entry:last-child .exp-line {
		display: none;
	}

	.exp-body {
		flex: 1;
		padding-bottom: 1.5rem;
	}

	.exp-entry:last-child .exp-body {
		padding-bottom: 0;
	}

	.exp-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 0.5rem;
		flex-wrap: wrap;
	}

	.exp-role {
		font-size: 1rem;
		color: var(--text-primary);
		margin: 0;
	}

	.exp-company {
		font-size: 0.85rem;
		color: var(--accent-primary);
		margin: 0.1rem 0 0 0;
	}

	.exp-meta {
		text-align: right;
		flex-shrink: 0;
	}

	.exp-date {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		color: var(--text-muted);
		display: block;
		margin-bottom: 0.2rem;
	}

	.exp-loc {
		display: inline-flex;
		align-items: center;
		gap: 0.2rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		color: var(--text-muted);
	}

	.exp-loc :global(svg) {
		color: var(--accent-primary);
	}

	.exp-highlights {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.exp-highlights li {
		position: relative;
		padding-left: 1.25rem;
		margin-bottom: 0.35rem;
		font-size: 0.85rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}

	.exp-highlights li::before {
		content: '>';
		position: absolute;
		left: 0;
		color: var(--accent-primary);
		font-family: 'JetBrains Mono', monospace;
		font-weight: 700;
	}

	.skills-clusters {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1.25rem;
	}

	.cluster-label {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.65rem;
		color: var(--text-muted);
		letter-spacing: 0.05em;
		text-transform: uppercase;
		margin: 0 0 0.6rem 0;
		padding-bottom: 0.35rem;
		border-bottom: 1px solid var(--border-color);
	}

	.cluster-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		padding: 0.2rem 0.5rem;
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
		color: var(--text-secondary);
		background: var(--bg-secondary);
	}

	.tag:hover {
		border-color: var(--accent-primary);
		color: var(--accent-primary);
	}

	.edu-entry {
		padding: 0.75rem 0;
		border-bottom: 1px solid var(--border-color);
	}

	.edu-entry:last-child {
		border-bottom: none;
	}

	.edu-degree {
		font-size: 0.95rem;
		color: var(--text-primary);
		margin: 0 0 0.1rem 0;
	}

	.edu-institution {
		font-size: 0.85rem;
		color: var(--accent-primary);
		margin: 0 0 0.35rem 0;
	}

	.edu-meta {
		display: flex;
		gap: 1rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		color: var(--text-muted);
	}

	@media (max-width: 768px) {
		.resume-page {
			grid-template-columns: 1fr;
			padding: 1.5rem 1rem;
			gap: 2rem;
		}

		.resume-sidebar {
			position: static;
			flex-direction: row;
			flex-wrap: wrap;
			gap: 1rem;
		}

		.resume-headshot {
			width: 100%;
			text-align: center;
		}

		.sidebar-section {
			flex: 1;
			min-width: 140px;
		}

		.resume-dl {
			width: 100%;
		}

		.exp-header {
			flex-direction: column;
		}

		.exp-meta {
			text-align: left;
		}

		.skills-clusters {
			grid-template-columns: 1fr;
		}
	}
</style>
