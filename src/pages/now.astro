---
import { Icon } from "astro-icon/components";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
import * as now from "../content/now.md";

const { Content, frontmatter } = now;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`Now - ${SITE_TITLE}`}
            description="What I'm doing now - Adrian Villanueva Martinez"
        />
    </head>
    <body>
        <a href="#main-content" class="skip-link">Skip to content</a>
        <Header />
        <main id="main-content" class="now-page" transition:name="page">
            <header class="now-header">
                <span class="now-label">NOW</span>
                <span class="now-date">{frontmatter.lastUpdated}</span>
            </header>
            <h1 class="now-title">What I'm focused on</h1>
            <div class="prose">
                <Content />
            </div>
            <footer class="now-footer">
                <p>
                    This page follows the
                    <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">/now movement</a>
                    — a way to share what you're focused on at this point in your life.
                </p>
            </footer>
        </main>
        <Footer />
    </body>
</html>

<style>
    .now-page {
        max-width: 640px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        animation: fadeInUp 0.6s ease-out;
    }

    .now-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .now-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        color: var(--accent-primary);
        letter-spacing: 0.15em;
    }

    .now-date {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        color: var(--text-muted);
        margin-left: auto;
        padding: 0.15rem 0.5rem;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
    }

    .now-title {
        font-size: clamp(1.5rem, 4vw, 2rem);
        margin: 0 0 2rem 0;
        background: none;
        -webkit-text-fill-color: initial;
        background-clip: initial;
        color: var(--text-primary);
    }

    .prose h3 {
        color: var(--accent-primary);
    }

    .now-footer {
        margin-top: 3rem;
        padding: 1.25rem;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        text-align: center;
    }

    .now-footer p {
        margin: 0;
        font-size: 0.8rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .now-footer a {
        color: var(--accent-primary);
    }

    .now-footer a:hover {
        color: var(--text-primary);
    }

    @media (max-width: 640px) {
        .now-page {
            padding: 2rem 1rem;
        }
    }
</style>
