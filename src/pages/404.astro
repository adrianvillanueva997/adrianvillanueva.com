---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`404 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="scene">
			<div class="void">
				<div class="ring"></div>
				<div class="ring ring-delayed"></div>
				<div class="code">404</div>
			</div>
			<h1 class="title">Lost in the Void</h1>
			<p class="subtitle">The page you seek does not exist here.</p>
			<a href="/" class="return">Return Home →</a>
		</main>
		<Footer />
	</body>
</html>

<style>
	.scene {
		min-height: 70vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	/* Void glow */
	.scene::before {
		content: "";
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 500px;
		height: 500px;
		background: radial-gradient(circle, var(--accent-blog-glow) 0%, transparent 60%);
		pointer-events: none;
		animation: breathe 6s ease-in-out infinite;
	}

	/* Rings */
	.void {
		position: relative;
		margin-bottom: 1.5rem;
	}

	.ring {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 160px;
		height: 160px;
		border: 1px solid var(--accent-blog);
		border-radius: 50%;
		opacity: 0.15;
		animation: expand-ring 4s ease-out infinite;
	}

	.ring-delayed {
		animation-delay: 2s;
	}

	.code {
		font-family: "Cinzel", serif;
		font-size: 7rem;
		font-weight: 700;
		line-height: 1;
		color: var(--text-primary);
		text-shadow:
			0 0 40px var(--accent-blog-glow),
			0 0 80px var(--accent-blog-glow);
		position: relative;
		z-index: 1;
		animation: fade-in 1.5s ease-out;
	}

	.title {
		font-family: "Cinzel", serif;
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 600;
		color: var(--text-primary);
		margin: 0 0 0.75rem;
		animation: fade-in 2s ease-out 0.3s both;
	}

	.subtitle {
		font-size: 0.95rem;
		color: var(--text-secondary);
		margin: 0 0 2rem;
		animation: fade-in 2s ease-out 0.6s both;
	}

	.return {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.7rem 1.5rem;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.85rem;
		color: var(--text-primary);
		text-decoration: none;
		border: 1px solid var(--accent-blog);
		border-radius: 100px;
		background: var(--accent-blog-subtle);
		transition: all var(--transition-base);
		animation: fade-in 2s ease-out 0.9s both;
	}

	.return:hover {
		background: var(--accent-blog);
		color: var(--bg-primary);
		box-shadow: 0 0 30px var(--accent-blog-glow);
	}

	@keyframes breathe {
		0%,
		100% {
			opacity: 0.5;
			transform: translate(-50%, -50%) scale(1);
		}
		50% {
			opacity: 1;
			transform: translate(-50%, -50%) scale(1.15);
		}
	}

	@keyframes expand-ring {
		0% {
			opacity: 0.25;
			transform: translate(-50%, -50%) scale(0.8);
		}
		100% {
			opacity: 0;
			transform: translate(-50%, -50%) scale(1.5);
		}
	}

	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 480px) {
		.code {
			font-size: 5rem;
		}

		.scene::before {
			width: 300px;
			height: 300px;
		}

		.ring {
			width: 120px;
			height: 120px;
		}
	}
</style>
