---
import { Image } from "astro:assets";
import { readFileSync } from "fs";
import { join } from "path";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";

const images = import.meta.glob("@/assets/**/*.{png,jpg,jpeg,webp,svg}", {
	eager: true,
});

const imageMap: Record<string, any> = {};
for (const path in images) {
	const filename = path.split("/").pop();
	if (filename) {
		imageMap[filename] = (images[path] as any).default;
	}
}

interface Project {
	title: string;
	description: string;
	href?: string;
	imgSrc?: string;
	categories?: string[];
	isOpenSource?: boolean;
	repoUrl?: string;
}

interface ProjectsData {
	projects: Project[];
}

const projectsPath = join(process.cwd(), "src/data/projects.yaml");
const projectsContent = readFileSync(projectsPath, "utf8");
const { load } = await import("js-yaml");
const projectsData = load(projectsContent) as ProjectsData;

const allProjects = projectsData.projects;

const allCategories = Array.from(
	new Set(
		projectsData.projects
			.flatMap((project) => project.categories || [])
			.filter(Boolean),
	),
).sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Projects - ${SITE_TITLE}`}
			description="Projects and work by Adrian Villanueva Martinez — data engineering, IoT, and software infrastructure."
		/>
	</head>
	<body>
		<Header />
		<main class="layout">
			<!-- Hero -->
			<section class="hero-card">
				<div class="hero-tagline">
					<span class="hero-marker">>></span>
					<span class="hero-label">PROJECTS</span>
				</div>
				<h1 class="hero-title">Selected Work</h1>
				<p class="hero-description">
					Engineering solutions across data platforms, IoT, and software
					infrastructure. Open-source and production systems built for scale.
				</p>
			</section>

			<!-- Filter -->
			<section class="section-block">
				<div class="section-head">
					<span class="section-marker">>></span>
					<h2 class="section-title">INDEX</h2>
				</div>
				<div class="filter-bar">
					<button class="filter-btn active" data-category="all">All</button>
					{allCategories.map((c) => (
						<button class="filter-btn" data-category={c.toLowerCase()}>
							{c}
						</button>
					))}
				</div>
			</section>

			<!-- Projects -->
			<section class="section-block">
				<div class="section-head">
					<span class="section-marker">>></span>
					<h2 class="section-title">DEPLOYMENTS</h2>
				</div>
				<div class="projects-grid">
					{allProjects.map((project, index) => (
						<article
							class="project-card"
							data-categories={
								project.categories
									?.map((c) => c.toLowerCase())
									.join(" ") || ""
							}
						>
							<div class="card-header-line">
								<span class="card-id">
									PRJ-{String(index + 1).padStart(4, "0")}
								</span>
								<span class="card-status">
									<span class="status-dot"></span>
									ONLINE
								</span>
							</div>
							<div class="card-media">
								{project.imgSrc && imageMap[project.imgSrc] ? (
									<Image
										src={imageMap[project.imgSrc]}
										alt={project.title}
										width={600}
										height={400}
										loading="lazy"
									/>
								) : (
									<div class="card-media-fallback">
										<span>{project.title.charAt(0)}</span>
									</div>
								)}
							</div>
							<div class="card-content">
								<div class="card-header">
									<h3 class="card-title">{project.title}</h3>
									{project.isOpenSource !== undefined && (
										<span
											class={`card-badge ${project.isOpenSource ? "open" : "closed"}`}
										>
											{project.isOpenSource ? "OPEN_SRC" : "PROPRIETARY"}
										</span>
									)}
								</div>
								<p class="card-description">{project.description}</p>
								{project.categories && project.categories.length > 0 && (
									<div class="card-tags">
										{project.categories.map((cat) => (
											<span class="tag">#{cat}</span>
										))}
									</div>
								)}
								<div class="card-actions">
									{project.isOpenSource && project.repoUrl && (
										<a
											href={project.repoUrl}
											target="_blank"
											rel="noopener noreferrer"
											class="action-link"
										>
											<span>SOURCE_CODE</span>
											<span class="action-arrow">→</span>
										</a>
									)}
									{project.href && (
										<a
											href={project.href}
											target="_blank"
											rel="noopener noreferrer"
											class="action-link primary"
										>
											<span>LIVE_DEMO</span>
											<span class="action-arrow">→</span>
										</a>
									)}
								</div>
							</div>
						</article>
					))}
				</div>
			</section>

			<!-- Technologies Overview -->
			<section class="section-block">
				<div class="section-head">
					<span class="section-marker">>></span>
					<h2 class="section-title">TECH_STACK</h2>
				</div>
				<div class="tech-table">
					<div class="tech-table-header">
						<span>DOMAIN</span>
						<span>COUNT</span>
						<span>STATUS</span>
					</div>
					<div class="tech-table-body">
						{allCategories.map((category) => (
							<div class="tech-row">
								<span class="tech-name">{category.toUpperCase()}</span>
								<span class="tech-count">
									{String(
										allProjects.filter((p) =>
											p.categories?.includes(category),
										).length,
									).padStart(2, "0")}
								</span>
								<span class="tech-status">ACTIVE</span>
							</div>
						))}
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<script>
			document.addEventListener("DOMContentLoaded", () => {
				const buttons = document.querySelectorAll(".filter-btn");
				const cards = document.querySelectorAll(".project-card");

				buttons.forEach((btn) => {
					btn.addEventListener("click", () => {
						const cat = btn.getAttribute("data-category");
						buttons.forEach((b) => b.classList.remove("active"));
						btn.classList.add("active");

						cards.forEach((card) => {
							const el = card;
							if (cat === "all") {
								el.style.display = "flex";
							} else {
								const cats = el.getAttribute("data-categories") || "";
								el.style.display = cats.includes(cat) ? "flex" : "none";
							}
						});
					});
				});
			});
		</script>
	</body>
</html>

<style>
	/* Hallmark · macrostructure: Portfolio Grid (tech accents) · genre: editorial
	 * pre-emit critique: P5 H4 E5 S5 R5 V4
	 */

	.layout {
		max-width: 960px;
		margin: 0 auto;
		padding: 2rem;
	}

	/* ── Hero ── */
	.hero-card {
		margin-bottom: 3rem;
		background: var(--glass-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		padding: 2.5rem;
		position: relative;
		overflow: hidden;
	}

	.hero-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 4px;
		height: 100%;
		background: var(--gradient-primary);
	}

	.hero-tagline {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.8rem;
	}

	.hero-marker {
		color: var(--accent-active);
		font-weight: 700;
	}

	.hero-label {
		color: var(--text-muted);
		letter-spacing: 0.05em;
	}

	.hero-title {
		font-family: "JetBrains Mono", monospace;
		font-size: 2rem;
		font-weight: 700;
		margin: 0 0 1rem;
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-description {
		font-size: 0.95rem;
		color: var(--text-secondary);
		line-height: 1.7;
		max-width: 600px;
		margin: 0;
	}

	/* ── Section block ── */
	.section-block {
		margin-bottom: 3rem;
	}

	.section-head {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border-color);
	}

	.section-marker {
		color: var(--accent-active);
		font-family: "JetBrains Mono", monospace;
		font-weight: 700;
		font-size: 0.9rem;
	}

	.section-title {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--text-muted);
		letter-spacing: 0.05em;
		margin: 0;
	}

	/* ── Filter ── */
	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.filter-btn {
		background: transparent;
		border: 1px solid var(--border-color);
		color: var(--text-secondary);
		padding: 0.4rem 1rem;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.8rem;
		cursor: pointer;
		border-radius: 100px;
		transition: all var(--transition-base);
	}

	.filter-btn:hover {
		border-color: var(--accent-active);
		color: var(--accent-active);
	}

	.filter-btn.active {
		background: var(--accent-active);
		border-color: var(--accent-active);
		color: var(--bg-primary);
		box-shadow: 0 0 20px var(--accent-active-glow);
	}

	/* ── Projects ── */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 1.25rem;
	}

	.project-card {
		background: var(--glass-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition: all var(--transition-base);
		position: relative;
	}

	.project-card:hover {
		border-color: var(--border-glow);
		transform: translateY(-3px);
		box-shadow: var(--shadow-glow), var(--shadow-md);
	}

	.card-header-line {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.4rem 1rem;
		background: var(--bg-secondary);
		border-bottom: 1px solid var(--border-color);
		font-family: "JetBrains Mono", monospace;
		font-size: 0.65rem;
		color: var(--text-muted);
	}

	.card-id {
		color: var(--accent-active);
		font-weight: 500;
	}

	.card-status {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--accent-active);
	}

	.status-dot {
		width: 6px;
		height: 6px;
		background: var(--accent-active);
		border-radius: 50%;
		box-shadow: 0 0 6px var(--accent-active);
		animation: pulse-dot 2s ease-in-out infinite;
	}

	.card-media {
		width: 100%;
		height: 200px;
		flex-shrink: 0;
		background: var(--bg-tertiary);
		overflow: hidden;
		position: relative;
	}

	.card-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border: none;
		border-radius: 0;
		transition: transform 0.4s ease, filter 0.4s ease;
		filter: grayscale(30%) contrast(1.05);
	}

	.project-card:hover .card-media img {
		transform: scale(1.03);
		filter: grayscale(0%) contrast(1) brightness(1.1);
	}

	.card-media-fallback {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(
			135deg,
			var(--bg-secondary),
			var(--bg-tertiary)
		);
		font-family: "Cinzel", serif;
		font-size: 2.5rem;
		color: var(--text-muted);
	}

	.card-content {
		flex: 1;
		padding: 1.25rem 1.5rem;
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.card-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.6rem;
	}

	.card-title {
		font-family: "JetBrains Mono", monospace;
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0;
	}

	.card-badge {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.6rem;
		padding: 0.15rem 0.45rem;
		border-radius: 100px;
		white-space: nowrap;
		flex-shrink: 0;
		letter-spacing: 0.03em;
	}

	.card-badge.open {
		color: var(--accent-active);
		border: 1px solid rgba(0, 230, 138, 0.3);
		background: var(--accent-active-subtle);
	}

	.card-badge.closed {
		color: var(--accent-blog);
		border: 1px solid var(--accent-blog);
		background: var(--accent-blog-subtle);
	}

	.card-description {
		font-size: 0.86rem;
		color: var(--text-secondary);
		line-height: 1.6;
		margin: 0 0 0.75rem;
		flex: 1;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		margin-bottom: 1rem;
	}

	.tag {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.65rem;
		color: var(--text-muted);
		padding: 0.1rem 0.45rem;
		border: 1px solid var(--border-color);
		border-radius: 100px;
		background: var(--bg-secondary);
		transition: all var(--transition-base);
	}

	.tag:hover {
		border-color: var(--accent-blog);
		color: var(--accent-blog);
		box-shadow: 0 0 8px var(--accent-blog-glow);
	}

	.card-actions {
		display: flex;
		gap: 0.75rem;
	}

	.action-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.45rem 0.9rem;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.7rem;
		color: var(--text-secondary);
		text-decoration: none;
		border: 1px solid var(--border-color);
		border-radius: 100px;
		transition: all var(--transition-base);
	}

	.action-link:hover {
		color: var(--accent-active);
		border-color: var(--accent-active);
		box-shadow: 0 0 12px var(--accent-active-glow);
	}

	.action-link.primary {
		background: var(--bg-secondary);
	}

	.action-link.primary:hover {
		background: var(--accent-active);
		border-color: var(--accent-active);
		color: var(--bg-primary);
		box-shadow: 0 0 20px var(--accent-active-glow);
	}

	/* ── Tech table ── */
	.tech-table {
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--glass-bg);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.tech-table-header {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		padding: 0.75rem 1rem;
		background: var(--bg-secondary);
		border-bottom: 1px solid var(--border-color);
		font-family: "JetBrains Mono", monospace;
		font-size: 0.7rem;
		color: var(--text-muted);
		font-weight: 700;
		letter-spacing: 0.05em;
	}

	.tech-table-body {
		display: flex;
		flex-direction: column;
	}

	.tech-row {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		padding: 0.7rem 1rem;
		border-bottom: 1px solid var(--border-color);
		font-family: "JetBrains Mono", monospace;
		font-size: 0.8rem;
		color: var(--text-secondary);
		transition: background 0.2s ease;
		align-items: center;
	}

	.tech-row:last-child {
		border-bottom: none;
	}

	.tech-row:hover {
		background: var(--accent-active-subtle);
	}

	.tech-name {
		color: var(--accent-active);
		font-weight: 500;
	}

	.tech-count {
		color: var(--text-primary);
		font-variant-numeric: tabular-nums;
	}

	.tech-status {
		color: var(--accent-active);
		font-size: 0.7rem;
		width: fit-content;
		padding: 0.1rem 0.5rem;
		border: 1px solid rgba(0, 230, 138, 0.2);
		border-radius: 100px;
	}

	/* ── Animations ── */
	@keyframes pulse-dot {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.4;
		}
	}

	/* ── Responsive ── */
	@media (max-width: 768px) {
		.layout {
			padding: 1rem;
		}

		.hero-card {
			padding: 1.5rem;
		}

		.hero-title {
			font-size: 1.5rem;
		}

		.card-media {
			height: 180px;
		}

		.tech-table-header,
		.tech-row {
			grid-template-columns: 1fr auto auto;
		}
	}

	@media (max-width: 480px) {
		.hero-card {
			padding: 1.25rem;
		}

		.hero-title {
			font-size: 1.3rem;
		}

		.card-header {
			flex-direction: column;
			gap: 0.5rem;
		}

		.card-content {
			padding: 1rem 1.25rem;
		}

		.card-actions {
			flex-direction: column;
		}

		.tech-table-header span:last-child,
		.tech-row span:last-child {
			display: none;
		}
	}
</style>
