---
import { Icon } from "astro-icon/components";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE, SOCIAL_LINKS } from "../consts";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`Contact - ${SITE_TITLE}`}
            description="Establish connection with Adrian Villanueva Martinez. Open for collaborations and technical discourse."
        />
    </head>
    <body>
        <Header />
        <main id="main-content" class="contact-page" transition:name="page">
            <header class="contact-header">
                <span class="contact-label">CONNECT</span>
                <h1 class="contact-title">Establish connection</h1>
                <p class="contact-sub">
                    Open for collaborations, technical discourse, and new opportunities.
                </p>
            </header>

            <div class="contact-channels">
                <a href={`mailto:${SOCIAL_LINKS.email}`} class="channel">
                    <span class="channel-icon"><Icon name="mdi:email" size={20} /></span>
                    <span class="channel-body">
                        <span class="channel-name">Email</span>
                        <span class="channel-value">{SOCIAL_LINKS.email}</span>
                    </span>
                    <span class="channel-arrow">&rarr;</span>
                </a>

                <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="channel">
                    <span class="channel-icon"><Icon name="mdi:linkedin" size={20} /></span>
                    <span class="channel-body">
                        <span class="channel-name">LinkedIn</span>
                        <span class="channel-value">@adrian-villanueva-martinez</span>
                    </span>
                    <span class="channel-arrow">&rarr;</span>
                </a>

                <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="channel">
                    <span class="channel-icon"><Icon name="mdi:github" size={20} /></span>
                    <span class="channel-body">
                        <span class="channel-name">GitHub</span>
                        <span class="channel-value">@adrianvillanueva997</span>
                    </span>
                    <span class="channel-arrow">&rarr;</span>
                </a>
            </div>

            <section class="topics-section">
                <div class="section-label">OPEN TO DISCUSS</div>
                <div class="topics-grid">
                    <div class="topic">
                        <Icon name="mdi:cloud" size={16} />
                        <span>Cloud-native data platforms & architecture</span>
                    </div>
                    <div class="topic">
                        <Icon name="mdi:database" size={16} />
                        <span>Data engineering & MLOps</span>
                    </div>
                    <div class="topic">
                        <Icon name="mdi:code-braces" size={16} />
                        <span>Open source contributions</span>
                    </div>
                    <div class="topic">
                        <Icon name="mdi:briefcase" size={16} />
                        <span>Technical consulting & collaboration</span>
                    </div>
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>

<style>
    .contact-page {
        max-width: 640px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        animation: fadeInUp 0.6s ease-out;
    }

    .contact-header {
        margin-bottom: 2.5rem;
    }

    .contact-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        color: var(--accent-primary);
        letter-spacing: 0.15em;
        margin-bottom: 0.75rem;
        display: inline-block;
    }

    .contact-title {
        font-size: clamp(1.5rem, 4vw, 2rem);
        margin: 0 0 0.5rem 0;
        background: none;
        -webkit-text-fill-color: initial;
        background-clip: initial;
        color: var(--text-primary);
    }

    .contact-sub {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin: 0;
    }

    .contact-channels {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 3rem;
    }

    .channel {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        text-decoration: none;
        transition: all var(--transition-base);
    }

    .channel:hover {
        border-color: rgba(0, 230, 138, 0.2);
        background: var(--bg-secondary);
        transform: translateX(4px);
    }

    .channel-icon {
        color: var(--accent-primary);
        line-height: 0;
        flex-shrink: 0;
    }

    .channel-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }

    .channel-name {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-primary);
        font-weight: 600;
    }

    .channel-value {
        font-size: 0.8rem;
        color: var(--text-muted);
        word-break: break-all;
    }

    .channel-arrow {
        color: var(--accent-primary);
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.1rem;
        opacity: 0;
        transform: translateX(-8px);
        transition: all var(--transition-base);
    }

    .channel:hover .channel-arrow {
        opacity: 1;
        transform: translateX(0);
    }

    .section-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        color: var(--accent-primary);
        letter-spacing: 0.15em;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border-color);
        display: inline-block;
    }

    .topics-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }

    .topic {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: var(--bg-tertiary);
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        color: var(--text-secondary);
        border: 1px solid transparent;
        transition: all var(--transition-fast);
    }

    .topic:hover {
        background: var(--accent-primary-subtle);
        border-color: rgba(0, 230, 138, 0.1);
        color: var(--text-primary);
    }

    .topic :global(svg) {
        color: var(--accent-primary);
        flex-shrink: 0;
    }

    @media (max-width: 640px) {
        .contact-page {
            padding: 2rem 1rem;
        }

        .topics-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
