---
import { Icon } from "astro-icon/components";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
import * as uses from "../content/uses.md";

const { Content, frontmatter } = uses;
const { hardware, peripherals, software } = frontmatter;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`Uses - ${SITE_TITLE}`}
            description="Hardware and software stack — Adrian Villanueva Martinez"
        />
    </head>
    <body>
        <Header />
        <main class="container">
            <!-- Hero -->
            <div class="page-hero">
                <p class="hero-label">TOOLS & INFRASTRUCTURE</p>
                <h1 class="page-title">USES</h1>
                <p class="page-subtitle">Hardware, software, and everything in between</p>
            </div>

            <!-- Hardware -->
            <div class="section-label">HARDWARE</div>
            <div class="card-grid">
                {hardware.map((item) => (
                    <div class="bento-item">
                        <div class="card-head">
                            <Icon name={item.icon} size={20} />
                            <span class="card-title">{item.name}</span>
                        </div>
                        <p class="card-desc">{item.desc}</p>
                        <p class="card-specs">{item.specs}</p>
                        <div class="tag-row">
                            {item.tags?.map((tag: string) => (
                                <span class="tag">{tag}</span>
                            ))}
                        </div>
                    </div>
                ))}
            </div>

            <!-- Peripherals -->
            <div class="section-label">PERIPHERALS</div>
            <div class="peripherals-row">
                {peripherals.map((item) => (
                    <div class="peripheral-item">
                        <Icon name={item.icon} size={16} />
                        <span>{item.name}</span>
                    </div>
                ))}
            </div>

            <!-- ✠ Divider -->
            <div class="doom-divider"><span>✠</span></div>

            <!-- Software -->
            <div class="section-label">SOFTWARE & ENVIRONMENT</div>
            <div class="card-grid">
                {software.map((item) => (
                    <div class="bento-item">
                        <div class="card-head">
                            <Icon name={item.icon} size={20} />
                            <span class="card-title">{item.name}</span>
                        </div>
                        <p class="card-category">{item.category}</p>
                        {item.note && <p class="card-note">{item.note}</p>}
                    </div>
                ))}
            </div>

            <!-- Content -->
            <div class="content-section">
                <Content />
            </div>

            <!-- Meta Footer -->
            <div class="meta-footer">
                <p>Last updated &mdash; {frontmatter.lastUpdated}. Follows the <a href="https://uses.tech" target="_blank" rel="noopener noreferrer">/uses movement</a>.</p>
            </div>
        </main>
        <Footer />
    </body>
</html>

<style>
    .container {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .page-hero {
        text-align: center;
        margin: 1rem 0 2.5rem;
    }

    .hero-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        color: var(--accent-blog);
        margin-bottom: 0.5rem;
    }

    .page-title {
        font-family: 'Cinzel', serif;
        font-size: 3rem;
        margin: 0;
        color: var(--text-primary);
        line-height: 1.1;
        animation: breathe 3s ease-in-out infinite;
        text-shadow: 0 0 40px var(--accent-blog-glow), 0 0 80px var(--accent-blog-glow);
    }

    @keyframes breathe {
        0%, 100% { text-shadow: 0 0 20px var(--accent-blog-glow), 0 0 40px var(--accent-blog-glow); }
        50% { text-shadow: 0 0 40px var(--accent-blog-glow), 0 0 80px var(--accent-blog-glow); }
    }

    .page-subtitle {
        font-size: 1rem;
        color: var(--text-muted);
        margin: 0.5rem 0 0;
    }

    .section-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        color: var(--accent-blog);
        margin-bottom: 1rem;
    }

    .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .bento-item {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 1.5rem;
        transition: all var(--transition-base);
        position: relative;
        overflow: hidden;
    }

    .bento-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--gradient-primary);
        transition: opacity var(--transition-base);
    }

    .bento-item:hover {
        border-color: color-mix(in srgb, var(--accent-blog) 40%, transparent);
        transform: translateY(-3px);
        box-shadow: 0 0 30px color-mix(in srgb, var(--accent-blog) 10%, transparent), var(--shadow-md);
    }

    .card-head {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.75rem;
    }

    .card-head :global(svg) {
        color: var(--accent-blog);
        flex-shrink: 0;
    }

    .card-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    .card-desc {
        font-size: 0.9rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0 0 0.5rem;
    }

    .card-specs {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0 0 0.75rem;
    }

    .card-category {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        color: var(--accent-blog);
        margin: 0;
    }

    .card-note {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin: 0.25rem 0 0;
    }

    .tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.05em;
        color: var(--accent-blog);
        background: color-mix(in srgb, var(--accent-blog) 10%, transparent);
        padding: 0.2rem 0.5rem;
        border-radius: var(--radius-sm);
        border: 1px solid color-mix(in srgb, var(--accent-blog) 15%, transparent);
    }

    .peripherals-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .peripheral-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 0.75rem;
        background: var(--glass-bg);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        color: var(--text-secondary);
        transition: all var(--transition-fast);
    }

    .peripheral-item:hover {
        border-color: color-mix(in srgb, var(--accent-blog) 30%, transparent);
        color: var(--text-primary);
    }

    .peripheral-item :global(svg) {
        color: var(--accent-blog);
    }

    .doom-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin: 2rem 0;
        color: var(--accent-blog);
        font-size: 1rem;
        opacity: 0.5;
        user-select: none;
    }

    .doom-divider::before,
    .doom-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, transparent, color-mix(in srgb, var(--accent-blog) 30%, transparent), transparent);
    }

    .content-section {
        margin-top: 1.5rem;
        padding: 1.5rem;
        background: var(--glass-bg);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        font-size: 0.9rem;
        color: var(--text-secondary);
        line-height: 1.7;
    }

    .meta-footer {
        margin: 3rem 0 2rem;
        padding: 1.5rem;
        background: var(--glass-bg);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        text-align: center;
    }

    .meta-footer p {
        margin: 0;
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .meta-footer a {
        color: var(--accent-blog);
        text-decoration: none;
        transition: color var(--transition-fast);
    }

    .meta-footer a:hover {
        color: var(--text-primary);
    }

    @media (max-width: 768px) {
        .page-title {
            font-size: 2.25rem;
        }

        .card-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
