---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import mePhoto from "@/assets/me/me.jpg";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
import * as about from "../content/about.md";

const { Content, frontmatter } = about;

const timeline = [
	{
		country: "Spain",
		flag: "🇪🇸",
		period: "1997 - 2021",
		years: "24 years",
		description: "Origin • Education • Early Career",
	},
	{
		country: "Netherlands",
		flag: "🇳🇱",
		period: "2021 - 2024",
		years: "3 years",
		description: "Amsterdam • Data Engineering",
	},
	{
		country: "Japan",
		flag: "🇯🇵",
		period: "2024 - Present",
		years: "Current",
		description: "Tokyo • Data Platform engineering",
	},
];
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`About - ${SITE_TITLE}`}
            description="About Adrian Villanueva Martinez - Software Engineer & Systems Designer"
        />
    </head>
    <body>
        <a href="#main-content" class="skip-link">Skip to content</a>
        <Header />
        <main id="main-content" class="about-page" transition:name="page">
            <aside class="about-sidebar">
                <div class="profile-stack">
                    <div class="avatar-frame">
                        <Image
                            src={mePhoto}
                            alt={frontmatter.name}
                            class="avatar"
                            width={120}
                            height={120}
                        />
                        <div class="status-dot"></div>
                    </div>
                    <h1 class="profile-name">{frontmatter.name}</h1>
                    <p class="profile-role">{frontmatter.occupation}</p>
                    <div class="profile-location">
                        <Icon name="mdi:map-marker" size={14} />
                        <span>Tokyo, Japan</span>
                    </div>
                    <div class="profile-social">
                        <a href={frontmatter.github} target="_blank" aria-label="GitHub">
                            <Icon name="mdi:github" size={20} />
                        </a>
                        <a href={frontmatter.linkedin} target="_blank" aria-label="LinkedIn">
                            <Icon name="mdi:linkedin" size={20} />
                        </a>
                        <a href={`mailto:${frontmatter.email}`} aria-label="Email">
                            <Icon name="mdi:email" size={20} />
                        </a>
                    </div>
                </div>
            </aside>

            <div class="about-main">
                <section class="bio-section">
                    <div class="section-label">BIO</div>
                    <div class="prose">
                        <Content />
                    </div>
                </section>

                <section class="timeline-section">
                    <div class="section-label">LOCATIONS</div>
                    <div class="timeline">
                        {timeline.map((entry, index) => (
                            <div class="tl-entry">
                                <div class="tl-line">
                                    <div class="tl-dot"></div>
                                    {index < timeline.length - 1 && <div class="tl-rule"></div>}
                                </div>
                                <div class="tl-body">
                                    <div class="tl-header">
                                        <span class="tl-flag">{entry.flag}</span>
                                        <h3 class="tl-country">{entry.country}</h3>
                                        <span class="tl-years">{entry.years}</span>
                                    </div>
                                    <div class="tl-period">{entry.period}</div>
                                    <div class="tl-desc">{entry.description}</div>
                                </div>
                            </div>
                        ))}
                    </div>
                </section>
            </div>
        </main>
        <Footer />
    </body>
</html>

<style>
    .about-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 2rem;
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 3rem;
        animation: fadeInUp 0.6s ease-out;
    }

    .about-sidebar {
        position: sticky;
        top: 6rem;
        align-self: start;
    }

    .profile-stack {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.75rem;
    }

    .avatar-frame {
        position: relative;
    }

    .avatar {
        border-radius: 50%;
        border: 2px solid var(--accent-primary);
        box-shadow: 0 0 20px var(--accent-primary-glow);
        width: 100px;
        height: 100px;
    }

    .status-dot {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 12px;
        height: 12px;
        background: var(--accent-primary);
        border-radius: 50%;
        border: 2px solid var(--bg-primary);
        animation: pulse-glow 2s ease-in-out infinite;
    }

    .profile-name {
        font-family: "Cinzel", serif;
        font-size: 1.3rem;
        margin: 0;
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.2;
    }

    .profile-role {
        font-size: 0.8rem;
        color: var(--accent-primary);
        font-weight: 500;
        letter-spacing: 0.05em;
        margin: 0;
    }

    .profile-location {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.3rem;
        font-size: 0.75rem;
        color: var(--text-muted);
        font-family: 'JetBrains Mono', monospace;
    }

    .profile-social {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.5rem;
    }

    .profile-social a {
        color: var(--text-muted);
        padding: 0.4rem;
        border-radius: var(--radius-sm);
        transition: all var(--transition-base);
        line-height: 0;
    }

    .profile-social a:hover {
        color: var(--accent-primary);
        background: var(--accent-primary-subtle);
    }

    .about-main {
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    .timeline {
        display: flex;
        flex-direction: column;
    }

    .tl-entry {
        display: flex;
        gap: 1.25rem;
    }

    .tl-line {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 0.35rem;
    }

    .tl-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid var(--accent-primary);
        background: var(--bg-primary);
        flex-shrink: 0;
        box-shadow: 0 0 8px var(--accent-primary-glow);
    }

    .tl-rule {
        width: 2px;
        flex: 1;
        background: linear-gradient(180deg, var(--accent-primary), transparent);
        margin-top: 0.4rem;
        opacity: 0.3;
        min-height: 2rem;
    }

    .tl-entry:last-child .tl-rule {
        display: none;
    }

    .tl-body {
        flex: 1;
        padding-bottom: 1.5rem;
    }

    .tl-entry:last-child .tl-body {
        padding-bottom: 0;
    }

    .tl-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.15rem;
        flex-wrap: wrap;
    }

    .tl-flag {
        font-size: 1.1rem;
        line-height: 1;
    }

    .tl-country {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.95rem;
        color: var(--text-primary);
        margin: 0;
        font-weight: 600;
    }

    .tl-years {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        color: var(--accent-primary);
        padding: 0.1rem 0.4rem;
        border: 1px solid rgba(0, 230, 138, 0.25);
        border-radius: var(--radius-sm);
        background: var(--accent-primary-subtle);
        margin-left: auto;
    }

    .tl-period {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 0.15rem;
    }

    .tl-desc {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    @media (max-width: 768px) {
        .about-page {
            grid-template-columns: 1fr;
            padding: 1.5rem 1rem;
            gap: 2rem;
        }

        .about-sidebar {
            position: static;
        }
    }
</style>
