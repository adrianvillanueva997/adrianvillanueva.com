---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { NOW_PREVIEW } from "@/data/current";
import { formatDate, getLatestBlogPost } from "@/utils/blog";

interface Props {
	mePhoto: ImageMetadata;
}

const { mePhoto } = Astro.props;

const timeline = [
	{
		country: "Spain",
		flag: "🇪🇸",
		period: "1997 - 2021",
		years: "24 years",
		description: "Origin • Education • Early Career",
	},
	{
		country: "Netherlands",
		flag: "🇳🇱",
		period: "2021 - 2024",
		years: "3 years",
		description: "Amsterdam • Data Engineering",
	},
	{
		country: "Japan",
		flag: "🇯🇵",
		period: "2024 - Present",
		years: "Current",
		description: "Tokyo • Data Platform Engineering",
	},
];

const nowItems = [
	{ label: "Learning", detail: NOW_PREVIEW.learning },
	{ label: "Reading", detail: NOW_PREVIEW.reading },
	{ label: "Building", detail: NOW_PREVIEW.building },
];

const creativeItems = [
	{ name: "Music", icon: "mdi:music", desc: "Synthwave + doom metal" },
	{
		name: "Photography",
		icon: "mdi:camera",
		desc: "Tokyo streets and beyond",
		href: "/photography",
	},
	{
		name: "Open Source",
		icon: "mdi:github",
		desc: "Data platforms & tooling",
		href: "https://github.com/adrianvillanueva997",
	},
];

const connectItems = [
	{
		name: "Email",
		icon: "mdi:email",
		href: "mailto:adrian.villanueva.martinez@outlook.com",
	},
	{
		name: "LinkedIn",
		icon: "mdi:linkedin",
		href: "https://linkedin.com/in/adrian-villanueva-martinez",
	},
	{
		name: "GitHub",
		icon: "mdi:github",
		href: "https://github.com/adrianvillanueva997",
	},
];

const latestPost = await getLatestBlogPost();
---

<section class="bento-grid">
    <!-- Profile Module -->
    <div class="bento-item profile-card">
        <div class="profile-header">
            <div class="avatar-container">
                <Image
                    src={mePhoto}
                    alt="Adrian Villanueva"
                    class="avatar"
                    width={80}
                    height={80}
                />
                <div class="status-indicator"></div>
            </div>
            <div class="profile-info">
                <h1 class="name">Adrian Villanueva</h1>
                <p class="role">Software Engineer</p>
                <div class="location">
                    <Icon name="mdi:map-marker" size={14} />
                    <span>Tokyo, JP</span>
                </div>
            </div>
        </div>
        <p class="bio">
            Spanish engineer building cloud-native data platforms.
            <br />Sometimes I make music and punch things.
        </p>
        <div class="social-links">
            <a
                href="https://github.com/adrianvillanueva997"
                target="_blank"
                aria-label="GitHub"
            >
                <Icon name="mdi:github" size={20} />
            </a>
            <a
                href="https://linkedin.com/in/adrian-villanueva-martinez"
                target="_blank"
                aria-label="LinkedIn"
            >
                <Icon name="mdi:linkedin" size={20} />
            </a>
            <a
                href="mailto:adrian.villanueva.martinez@outlook.com"
                aria-label="Email"
            >
                <Icon name="mdi:email" size={20} />
            </a>
        </div>
        <a href="/about" class="about-btn">
            <span class="btn-bracket">[</span>
            ABOUT ME
            <span class="btn-bracket">]</span>
        </a>
    </div>

    <!-- The Journey -->
    <div class="bento-item journey-card">
        <div class="module-header">
            <Icon name="mdi:map-marker-path" size={16} />
            <span class="module-title">THE ROUTE HERE</span>
        </div>
        <div class="journey-content">
            {timeline.map((entry, index) => (
                <div class="journey-entry">
                    <div class="journey-marker">
                        <div class="marker-dot"></div>
                        {index < timeline.length - 1 && <div class="marker-line"></div>}
                    </div>
                    <div class="journey-info">
                        <div class="journey-header">
                            <span class="journey-flag">{entry.flag}</span>
                            <span class="journey-country">{entry.country}</span>
                            <span class="journey-years">{entry.years}</span>
                        </div>
                        <div class="journey-period">{entry.period}</div>
                        <div class="journey-desc">{entry.description}</div>
                    </div>
                </div>
            ))}
        </div>
    </div>

    <!-- Latest Blog Post -->
    <div class="bento-item latest-blog">
        <div class="module-header">
            <Icon name="mdi:pencil" size={16} />
            <span class="module-title">LATEST POST</span>
        </div>
        <div class="blog-content">
            {latestPost ? (
                <>
                    <h3 class="blog-title">{latestPost.title}</h3>
                    {latestPost.pubDate && (
                        <span class="blog-date">{formatDate(latestPost.pubDate)}</span>
                    )}
                    {latestPost.description && (
                        <p class="blog-description">{latestPost.description}</p>
                    )}
                    <a href="/blog" class="read-more">Read more &rarr;</a>
                </>
            ) : (
                <>
                    <p class="blog-fallback">Check back soon for new articles on systems engineering and cloud infrastructure.</p>
                    <a href="/blog" class="read-more">Read more &rarr;</a>
                </>
            )}
        </div>
    </div>

    <!-- Now -->
    <div class="bento-item now-card">
        <div class="module-header">
            <Icon name="mdi:clock-outline" size={16} />
            <span class="module-title">NOW</span>
        </div>
        <div class="now-content">
            {nowItems.map((item) => (
                <div class="now-item">
                    <span class="now-label">{item.label}</span>
                    <span class="now-detail">{item.detail}</span>
                </div>
            ))}
        </div>
        <a href="/now" class="card-link">What else am I up to &rarr;</a>
    </div>

    <!-- Creative Side -->
    <div class="bento-item creative-card">
        <div class="module-header">
            <Icon name="mdi:lightbulb-outline" size={16} />
            <span class="module-title">CREATIVE SIDE</span>
        </div>
        <div class="creative-content">
            {creativeItems.map((item) => (
                <a
                    href={item.href || "#"}
                    target={item.href?.startsWith("http") ? "_blank" : undefined}
                    rel={item.href?.startsWith("http") ? "noopener noreferrer" : undefined}
                    class="creative-item"
                >
                    <Icon name={item.icon} size={18} />
                    <div class="creative-info">
                        <span class="creative-name">{item.name}</span>
                        <span class="creative-desc">{item.desc}</span>
                    </div>
                </a>
            ))}
            <blockquote class="creative-quote">
                "Code and music share the same DNA: structure, rhythm, and creative expression."
            </blockquote>
        </div>
    </div>

    <!-- Connect -->
    <div class="bento-item connect-card">
        <div class="module-header">
            <Icon name="mdi:chat" size={16} />
            <span class="module-title">CONNECT</span>
        </div>
        <div class="connect-content">
            {connectItems.map((item) => (
                <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="connect-item"
                >
                    <Icon name={item.icon} size={18} />
                    <span>{item.name}</span>
                </a>
            ))}
        </div>
    </div>
</section>

<style>
    .bento-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1.5rem;
        margin: 2rem 0 4rem 0;
        animation: fadeInUp 0.6s ease-out;
    }

    .bento-item {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        transition: all var(--transition-base);
        position: relative;
        overflow: hidden;
    }

    .bento-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--gradient-primary);
        transition: opacity var(--transition-base);
    }

    .bento-item:hover {
        border-color: var(--border-glow);
        transform: translateY(-3px);
        box-shadow: var(--shadow-glow), var(--shadow-md);
    }

    .module-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-muted);
        letter-spacing: 0.05em;
    }

    .text-active {
        color: var(--accent-active);
    }

    /* Profile Card - Col 1, Rows 1-2 */
    .profile-card {
        grid-column: 1;
        grid-row: 1 / 3;
        justify-content: flex-start;
        text-align: center;
    }

    .profile-header {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: center;
        text-align: center;
    }

    .avatar {
        border-radius: 50%;
        border: 2px solid var(--accent-active);
        box-shadow: 0 0 20px var(--accent-active-glow);
        transition: all 0.3s ease;
        width: 64px;
        height: 64px;
    }

    .bento-item:hover .avatar {
        transform: scale(1.08);
        box-shadow: 0 0 30px var(--accent-active-glow);
    }

    .avatar-container {
        position: relative;
    }

    .status-indicator {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 12px;
        height: 12px;
        background-color: var(--accent-active);
        border-radius: 50%;
        border: 2px solid var(--bg-secondary);
        animation: pulse-glow 2s ease-in-out infinite;
    }

    .profile-info {
        width: 100%;
    }

    .name {
        font-family: "Cinzel", serif;
        font-size: 1.1rem;
        margin: 0 0 0.2rem 0;
        line-height: 1.2;
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .role {
        color: var(--accent-active);
        font-size: 0.75rem;
        margin-bottom: 0.4rem;
        font-weight: 500;
        letter-spacing: 0.05em;
    }

    .location {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        font-size: 0.7rem;
        color: var(--text-muted);
        font-family: 'JetBrains Mono', monospace;
    }

    .bio {
        margin: 1rem 0 0.75rem 0;
        font-size: 0.8rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    .social-links {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        margin-bottom: 0.75rem;
    }

    .social-links a {
        color: var(--text-muted);
        transition: all var(--transition-base);
        padding: 0.4rem;
        border-radius: var(--radius-sm);
    }

    .social-links a:hover {
        color: var(--accent-active);
        background: var(--accent-active-subtle);
        transform: translateY(-2px);
    }

    .about-btn {
        margin: auto 0 0 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        padding: 0.5rem 1rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: var(--text-secondary);
        text-decoration: none;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        transition: all var(--transition-base);
    }

    .about-btn:hover {
        color: var(--accent-active);
        border-color: var(--border-glow);
        box-shadow: 0 0 20px var(--accent-active-glow);
    }

    .btn-bracket {
        color: var(--accent-active);
    }

    /* Journey Card - Cols 2-3, Row 1 */
    .journey-card {
        grid-column: 2 / 4;
        grid-row: 1;
    }

    .journey-content {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .journey-entry {
        display: flex;
        gap: 1rem;
    }

    .journey-marker {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 0.25rem;
    }

    .marker-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid var(--accent-active);
        background: var(--bg-secondary);
        flex-shrink: 0;
        box-shadow: 0 0 8px var(--accent-active-glow);
    }

    .marker-line {
        width: 2px;
        flex: 1;
        background: linear-gradient(180deg, var(--accent-active), transparent);
        margin-top: 0.4rem;
        opacity: 0.3;
        min-height: 2rem;
    }

    .journey-entry:last-child .marker-line {
        display: none;
    }

    .journey-info {
        flex: 1;
        padding-bottom: 1.25rem;
    }

    .journey-entry:last-child .journey-info {
        padding-bottom: 0;
    }

    .journey-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.15rem;
        flex-wrap: wrap;
    }

    .journey-flag {
        font-size: 1.2rem;
        line-height: 1;
    }

    .journey-country {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.9rem;
        color: var(--text-primary);
        font-weight: 600;
    }

    .journey-years {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        color: var(--accent-active);
        padding: 0.1rem 0.4rem;
        border: 1px solid rgba(0, 230, 138, 0.25);
        border-radius: var(--radius-sm);
        background: var(--accent-active-subtle);
        margin-left: auto;
    }

    .journey-period {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 0.15rem;
    }

    .journey-desc {
        font-size: 0.8rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    /* Latest Blog Post - Col 1, Row 3 */
    .latest-blog {
        grid-column: 1;
        grid-row: 3;
    }

    .latest-blog::before {
        background: var(--accent-blog);
        opacity: 0.3;
    }

    .latest-blog:hover::before {
        opacity: 1;
    }

    .blog-content {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1;
    }

    .blog-title {
        margin: 0;
        font-size: 0.95rem;
        border: none;
        padding: 0;
        line-height: 1.3;
        color: var(--text-primary);
        font-weight: 600;
        transition: color 0.2s ease;
    }

    .blog-title:hover {
        color: var(--accent-blog);
    }

    .blog-description {
        margin: 0;
        font-size: 0.8rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    .blog-fallback {
        margin: 0;
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    .blog-date {
        font-size: 0.7rem;
        color: var(--text-muted);
        font-family: 'JetBrains Mono', monospace;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .read-more {
        margin-top: auto;
        font-size: 0.75rem;
        color: var(--accent-blog);
        text-decoration: none;
        transition: all var(--transition-base);
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .read-more:hover {
        color: var(--accent-blog);
        transform: translateX(4px);
        filter: brightness(1.3);
    }

    /* Now Card - Cols 2-3, Row 2 */
    .now-card {
        grid-column: 2 / 4;
        grid-row: 2;
    }

    .now-content {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1;
    }

    .now-item {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        font-size: 0.85rem;
    }

    .now-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        min-width: 5rem;
        flex-shrink: 0;
    }

    .now-detail {
        color: var(--text-primary);
        line-height: 1.4;
    }

    .card-link {
        margin-top: auto;
        font-size: 0.75rem;
        color: var(--accent-active);
        text-decoration: none;
        transition: all var(--transition-base);
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding-top: 0.75rem;
    }

    .card-link:hover {
        transform: translateX(4px);
    }

    /* Creative Card - Col 2, Row 3 */
    .creative-card {
        grid-column: 2;
        grid-row: 3;
    }

    .creative-content {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1;
    }

    .creative-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem;
        border-radius: var(--radius-sm);
        text-decoration: none;
        color: var(--text-secondary);
        transition: all var(--transition-fast);
    }

    .creative-item:hover {
        background: var(--accent-active-subtle);
        color: var(--accent-active);
    }

    .creative-info {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }

    .creative-name {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-primary);
    }

    .creative-item:hover .creative-name {
        color: var(--accent-active);
    }

    .creative-desc {
        font-size: 0.7rem;
        color: var(--text-muted);
        line-height: 1.3;
    }

    .creative-quote {
        margin: auto 0 0 0;
        padding: 0.75rem;
        border-left: 2px solid var(--accent-blog);
        background: var(--accent-blog-subtle);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        font-size: 0.75rem;
        font-style: italic;
        color: var(--text-secondary);
        line-height: 1.4;
        backdrop-filter: none;
    }

    /* Connect Card - Col 3, Row 3 */
    .connect-card {
        grid-column: 3;
        grid-row: 3;
    }

    .connect-content {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
    }

    .connect-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem;
        border-radius: var(--radius-sm);
        text-decoration: none;
        color: var(--text-secondary);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        transition: all var(--transition-fast);
    }

    .connect-item:hover {
        background: var(--accent-active-subtle);
        color: var(--accent-active);
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .bento-grid {
            grid-template-columns: 1fr 1fr;
        }

        .profile-card {
            grid-column: 1 / 3;
            grid-row: 1;
        }

        .journey-card {
            grid-column: 1 / 3;
            grid-row: 2;
        }

        .latest-blog {
            grid-column: 1;
            grid-row: 3;
        }

        .now-card {
            grid-column: 2;
            grid-row: 3;
        }

        .creative-card {
            grid-column: 1;
            grid-row: 4;
        }

        .connect-card {
            grid-column: 2;
            grid-row: 4;
        }
    }

    @media (max-width: 640px) {
        .bento-grid {
            display: flex;
            flex-direction: column;
        }

        .creative-quote {
            font-size: 0.7rem;
        }
    }
</style>
