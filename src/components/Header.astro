---
import HeaderLink from "@/components/HeaderLink.astro";
import { NAV_ITEMS, SITE_TITLE } from "@/consts";

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^/]+/g);
const currentSegment = "/" + (subpath?.[0] || "");
---

<header>
	<nav>
		<div class="logo">
			<a href="/"><span class="monogram">AVM/</span> {SITE_TITLE}</a>
		</div>

		<!-- Mobile Menu Toggle -->
		<button
			class="mobile-menu-toggle"
			aria-label="Toggle menu"
			aria-expanded="false"
		>
			<span class="hamburger"></span>
			<span class="hamburger"></span>
			<span class="hamburger"></span>
		</button>

		<!-- Navigation Menu -->
		<div class="nav-menu">
			{
				NAV_ITEMS.map((item) => {
					if ("children" in item) {
						const isActive = item.children.some(
							(c) =>
								c.href === pathname ||
								c.href === currentSegment,
						);
						return (
							<div
								class:list={["nav-item", "dropdown", { active: isActive }]}
							>
								<span class="dropdown-trigger">
									{item.label}
									<span class="dropdown-arrow"></span>
								</span>
								<div class="dropdown-menu">
									{
										item.children.map((child) => (
											<HeaderLink href={child.href}>
												{child.label}
											</HeaderLink>
										))
									}
								</div>
							</div>
						);
					}
					return (
						<HeaderLink href={item.href}>
							{item.label}
						</HeaderLink>
					);
				})
			}
		</div>
	</nav>
</header>

<script>
	// Mobile menu toggle
	const menuToggle = document.querySelector('.mobile-menu-toggle');
	const navMenu = document.querySelector('.nav-menu');
	const body = document.body;

	menuToggle?.addEventListener('click', () => {
		const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
		menuToggle.setAttribute('aria-expanded', (!isExpanded).toString());
		menuToggle.classList.toggle('active');
		navMenu?.classList.toggle('active');
		body.classList.toggle('menu-open');
	});

	// Close menu when clicking any nav link (flat or dropdown child)
	const navLinks = document.querySelectorAll('.nav-menu a');
	navLinks.forEach((link) => {
		link.addEventListener('click', () => closeMenu());
	});

	// Close menu on Escape
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && navMenu?.classList.contains('active')) {
			closeMenu();
			menuToggle?.focus();
		}
	});

	// Trap focus within mobile menu when open
	navMenu?.addEventListener('keydown', (e) => {
		if (e.key !== 'Tab' || !navMenu?.classList.contains('active')) return;
		const focusable = navMenu.querySelectorAll<HTMLElement>(
			'a, button, [tabindex]:not([tabindex="-1"])'
		);
		if (focusable.length === 0) return;
		const first = focusable[0];
		const last = focusable[focusable.length - 1];
		if (e.shiftKey && document.activeElement === first) {
			e.preventDefault();
			last.focus();
		} else if (!e.shiftKey && document.activeElement === last) {
			e.preventDefault();
			first.focus();
		}
	});

	// Mobile dropdown toggle
	const dropdownTriggers = document.querySelectorAll('.dropdown-trigger');
	dropdownTriggers.forEach((trigger) => {
		trigger.addEventListener('click', (e) => {
			if (window.innerWidth > 768) return;
			e.preventDefault();
			const dropdown = trigger.closest('.dropdown');
			dropdown?.classList.toggle('expanded');
		});
	});

	function closeMenu() {
		menuToggle?.classList.remove('active');
		navMenu?.classList.remove('active');
		body.classList.remove('menu-open');
		menuToggle?.setAttribute('aria-expanded', 'false');
		// Collapse any expanded dropdowns
		document.querySelectorAll('.dropdown.expanded').forEach((d) =>
			d.classList.remove('expanded')
		);
	}
</script>

<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		background: rgba(8, 9, 10, 0.8);
		backdrop-filter: blur(20px) saturate(180%);
		-webkit-backdrop-filter: blur(20px) saturate(180%);
		border-bottom: 1px solid var(--border-color);
		padding: 0;
	}

	header::after {
		content: '';
		position: absolute;
		bottom: -1px;
		left: 0;
		right: 0;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--accent-active), var(--accent-info), transparent);
		opacity: 0.4;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 2rem;
	}

	.logo {
		font-family: 'JetBrains Mono', monospace;
		font-weight: 700;
		font-size: 1.125rem;
		z-index: 1001;
		letter-spacing: -0.02em;
	}

	.logo a {
		color: var(--text-primary);
		text-decoration: none;
		transition: all var(--transition-base);
		background: linear-gradient(135deg, var(--text-primary), var(--accent-active));
		-webkit-background-clip: text;
		background-clip: text;
	}

	.logo a:hover {
		-webkit-text-fill-color: transparent;
		text-shadow: none;
		filter: brightness(1.2);
	}

	.monogram {
		font-weight: 700;
	}

	.nav-menu {
		display: flex;
		gap: 0.25rem;
		align-items: center;
	}

	/* ── Dropdown ── */
	.nav-item.dropdown {
		position: relative;
	}

	.dropdown-trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-family: 'JetBrains Mono', monospace;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-size: 0.8rem;
		padding: 0.5rem 0.75rem;
		color: var(--text-secondary);
		cursor: default;
		border: 1px solid transparent;
		border-radius: var(--radius-sm);
		transition: all var(--transition-base);
	}

	.dropdown-trigger:hover {
		color: var(--accent-active);
		background: var(--accent-active-subtle);
		border-color: rgba(0, 230, 138, 0.15);
	}

	.dropdown.active .dropdown-trigger {
		color: var(--text-primary);
		background: var(--bg-tertiary);
		border-color: var(--border-light);
		text-shadow: 0 0 10px var(--accent-blog-glow);
	}

	.dropdown-arrow {
		display: inline-block;
		width: 0;
		height: 0;
		border-left: 4px solid transparent;
		border-right: 4px solid transparent;
		border-top: 4px solid currentColor;
		transition: transform var(--transition-fast);
	}

	.dropdown:hover .dropdown-arrow,
	.dropdown.expanded .dropdown-arrow {
		transform: rotate(180deg);
	}

	.dropdown-menu {
		display: none;
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%);
		min-width: 140px;
		background: var(--bg-primary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		padding: 0.5rem;
		z-index: 1002;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
	}

	.dropdown-menu::before {
		content: '';
		position: absolute;
		top: -5px;
		left: 50%;
		transform: translateX(-50%) rotate(45deg);
		width: 8px;
		height: 8px;
		background: var(--bg-primary);
		border-left: 1px solid var(--border-color);
		border-top: 1px solid var(--border-color);
	}

	.dropdown-menu :global(a) {
		display: block;
		padding: 0.5rem 1rem;
		font-size: 0.75rem;
		white-space: nowrap;
		border-radius: var(--radius-sm);
	}

	.dropdown-menu :global(a:hover) {
		background: var(--accent-active-subtle);
	}

	.dropdown:hover .dropdown-menu {
		display: block;
	}

	/* ── Mobile menu toggle ── */
	.mobile-menu-toggle {
		display: none;
		flex-direction: column;
		gap: 4px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
		z-index: 1001;
	}

	.hamburger {
		display: block;
		width: 24px;
		height: 2px;
		background: var(--text-primary);
		transition: all 0.2s ease;
	}

	.mobile-menu-toggle.active .hamburger:nth-child(1) {
		transform: rotate(45deg) translate(5px, 5px);
	}

	.mobile-menu-toggle.active .hamburger:nth-child(2) {
		opacity: 0;
	}

	.mobile-menu-toggle.active .hamburger:nth-child(3) {
		transform: rotate(-45deg) translate(6px, -6px);
	}

	:global(body) {
		padding-top: 80px;
	}

	:global(body.menu-open) {
		overflow: hidden;
	}

	:global(body.menu-open::after) {
		content: '';
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		z-index: 999;
	}

	@media (max-width: 768px) {
		nav {
			padding: 1rem 1.5rem;
		}

		.logo {
			font-size: 1rem;
		}

		.mobile-menu-toggle {
			display: flex;
		}

		.nav-menu {
			position: fixed;
			top: 0;
			right: -100%;
			width: 70%;
			max-width: 280px;
			height: 100vh;
			background: var(--bg-primary);
			flex-direction: column;
			gap: 0;
			padding: 5rem 2rem 2rem;
			transition: right 0.3s ease;
			border-left: 1px solid var(--bg-tertiary);
			align-items: flex-start;
			overflow-y: auto;
		}

		.nav-menu.active {
			right: 0;
		}

		/* Mobile flat links */
		.nav-menu > :global(a) {
			padding: 1rem 0;
			border-bottom: 1px solid var(--bg-tertiary);
			font-size: 1rem;
			display: block;
			width: 100%;
		}

		/* Mobile dropdown */
		.nav-item.dropdown {
			width: 100%;
			border-bottom: 1px solid var(--bg-tertiary);
		}

		.dropdown-trigger {
			width: 100%;
			padding: 1rem 0;
			font-size: 1rem;
			cursor: pointer;
			justify-content: space-between;
			border: none;
			border-radius: 0;
		}

		.dropdown-trigger:hover {
			background: none;
			border-color: transparent;
		}

		.dropdown-menu {
			display: none;
			position: static;
			transform: none;
			background: none;
			border: none;
			box-shadow: none;
			padding: 0 0 0.5rem 1rem;
		}

		.dropdown-menu::before {
			display: none;
		}

		.dropdown.expanded .dropdown-menu {
			display: block;
		}

		.dropdown-menu :global(a) {
			padding: 0.75rem 0;
			font-size: 0.9rem;
			border-bottom: 1px solid var(--bg-tertiary);
		}

		:global(body) {
			padding-top: 60px;
		}
	}

	@media (max-width: 480px) {
		nav {
			padding: 1rem;
		}

		.logo {
			font-size: 0.9rem;
		}

		.nav-menu {
			width: 80%;
		}
	}
</style>
